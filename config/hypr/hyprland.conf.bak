# Minimal test config for Hyprland
monitor=,preferred,auto,1

exec-once = quickshell -c ~/reference/testrepos/quickshell/shell.qml
# exec-once = ~/.local/share/quickshell-lockscreen/lock.sh

input {
    kb_layout = us,jp
    kb_variant =
    kb_options = grp:lalt_lshift_toggle
}

$mainMod = SUPER

bind = $mainMod, Q, exec, foot
bind = $mainMod, T, exec, foot
bind = $mainMod, W, killactive
bind = $mainMod, RETURN, exec, foot
bind = $mainMod, L, exec, ~/.local/bin/random-lock.sh
bind = $mainMod, SPACE, exec, ~/.local/bin/random-lock.sh

bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5

bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5

general {
    gaps_in = 4
    gaps_out = 8
    border_size = 2
    col.active_border = rgba(6750a4ff)
    col.inactive_border = rgba(49454fff)
}

decoration {
    rounding = 12
    blur {
        enabled = true
        size = 6
        passes = 3
    }
}
