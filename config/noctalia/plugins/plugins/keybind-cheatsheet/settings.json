        {
          "keys": "Vol Down",
          "desc": "Run: pactl set-sink-volume @DEFAULT_SINK@ -5%"
        },
        {
          "keys": "Mute",
          "desc": "Run: pactl set-sink-mute @DEFAULT_SINK@ toggle"
