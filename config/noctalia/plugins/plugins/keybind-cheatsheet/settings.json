        {
          "keys": "Mic Mute",
          "desc": "Run: pactl set-source-mute @DEFAULT_SOURCE@ toggle"
        },
        {
          "keys": "F3",
          "desc": "Run: pactl set-sink-volume @DEFAULT_SINK@ +5%"
